# ============================================================================
# LifeSync Web Application - Environment Variables
# ============================================================================

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
BASEPATH=
NEXT_PUBLIC_APP_URL=http://localhost:3000${BASEPATH}

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# Remote API Configuration (LifeSync Backend)
# -----------------------------------------------------------------------------
# Base URL for the LifeSync API (Remote Backend)
# Development: http://localhost:4000/api
# Production: https://api.lifesync.app/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# API request timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=30000

# Application environment (development, production, staging)
NEXT_PUBLIC_ENV=development

# -----------------------------------------------------------------------------
# Authentication (JWT - Managed by Remote API)
# -----------------------------------------------------------------------------
# JWT tokens are automatically handled by the API client using httpOnly cookies
# No additional configuration needed here

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
# These variables are used when running the app in Docker containers
# They will be overridden by docker-compose.yml environment section
