# Development Dockerfile for LifeSync Web Application
FROM node:20-alpine

# Install dependencies for node-gyp and other native modules
# RUN apk add --no-cache libc6-compat python3 make g++

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./
COPY pnpm-lock.yaml* ./

# Install pnpm
# RUN npm install -g pnpm

# Install dependencies
# RUN npm install

# Copy all project files
COPY . .

# Expose port 3000 for Next.js development server
EXPOSE 3000

# Start development server with hot reload
CMD ["npm", "run", "dev"]
