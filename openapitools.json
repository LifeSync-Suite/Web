{
  "$schema": "node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.10.0",
    "generators": {
      "typescript": {
        "generatorName": "typescript-axios",
        "output": "./src/lib/api/generated",
        "glob": "swagger.json",
        "additionalProperties": {
          "supportsES6": "true",
          "withInterfaces": "true",
          "useSingleRequestParameter": "true"
        }
      }
    }
  }
}
